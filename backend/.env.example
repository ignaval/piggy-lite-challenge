# Copy to `.env` and adjust as needed. All values have working defaults, so the
# app runs even without a .env file.

# SQLite by default — a file created next to where you run the app.
DATABASE_URL=sqlite:///./piggy_lite.db

# Secret that gates the /api/v1/e2e/* helper routes.
E2E_SECRET=dev-e2e-secret

# Comma-or-JSON list of allowed CORS origins (the Next.js dev server).
# BACKEND_CORS_ORIGINS=["http://localhost:3000"]
